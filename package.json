{
  "name": "obsidian-all-in-one-toolkit",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/heic-decode": "^2.0.0",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "heic-decode": "^2.1.0",
    "obsidian": "^1.13.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "download"
    }
  }
}
